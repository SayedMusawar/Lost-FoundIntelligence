# Copy these variable names into Railway → Variables tab
# and fill in the actual values

# PostgreSQL connection string (Railway provides this automatically
# when you add a PostgreSQL plugin — copy it from Railway's Variables tab)
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# Secret key for JWT / session signing (make up any long random string)
SECRET_KEY=your-very-long-random-secret-key-here

# Frontend URL for CORS (your Vercel URL, e.g. https://your-app.vercel.app)
FRONTEND_URL=https://your-app.vercel.app
